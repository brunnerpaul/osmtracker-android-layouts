<layouts>
    <layout name="page1">
        <row> <!-- surface, the most common values for off-road cycling first -->
            <button type="tag" label="compacted" />
            <button type="tag" label="dirt" />
            <button type="tag" label="asphalt" />
            <button type="page" label="next page" targetlayout="page2" />
        </row>
        <row> <!-- tracktype (tracktype=grade1 = surface=paved/asphalt, so not needed here) -->
            <button type="tag" label="track 2" />
            <button type="tag" label="track 3" />
            <button type="tag" label="track 4" />
            <button type="tag" label="track 5" />
        </row>
        <row> <!-- smoothness -->
            <button type="tag" label="good" />
            <button type="tag" label="intermediate" />
            <button type="tag" label="bad" />
            <button type="tag" label="very bad" />
        </row>
    </layout>
    <layout name="page2">
         <row> <!-- less common surface values on the same row as page 1 -->
            <button type="tag" label="concrete" />
            <button type="tag" label="paving stones" />
            <button type="tag" label="sett" />
            <button type="page" label="next page" targetlayout="page3" />
        </row>
        <row> <!-- maxspeed row 1 -->
            <button type="tag" label="20 km/h" />
            <button type="tag" label="30 km/h" />
            <button type="tag" label="40 km/h" />
            <button type="tag" label="50 km/h" />
        </row>
        <row> <!-- maxspeed row 2 -->
            <button type="tag" label="60 km/h" /> <!--  icons disabled for less common values to save space, icon="cycling_3_rows_icons/60.png" -->
            <button type="tag" label="70 km/h" /> <!--  icon="cycling_3_rows_icons/70.png" -->
            <button type="tag" label="80 km/h" /> <!--  icon="cycling_3_rows_icons/80.png" -->
            <button type="tag" label="speed limit end" />
        </row>
    </layout>
    <layout name="page3">
        <row> <!-- marking viewpoints and nice sections of a route -->
            <button type="tag" label="viewpoint" />
            <button type="tag" label="start nice" />
            <button type="tag" label="end nice" />
            <button type="page" label="next page" targetlayout="page4" />
        </row>
        <row> <!-- drinking_water (named "well" for layout purposes) -->
            <button type="tag" label="well left" />
            <button type="tag" label="well right" />
            <button type="tag" label="wheelchair yes" />
            <button type="tag" label="well, not drinkable" />
        </row>
        <row> <!-- width of path/track/road-->
            <button type="tag" label="0.5m" />
            <button type="tag" label="0.8m" />
            <button type="tag" label="1.2m" />
            <button type="tag" label="2.5m" />
            <button type="tag" label="3.4m" />
        </row>
    </layout>
    <layout name="page4">
        <row> <!--motor_vehicle access values-->
            <button type="tag" label="forestry mv" />
            <button type="tag" label="agricultural mv" />
            <button type="tag" label="no motor vehicle" />
            <button type="page" label="next page" targetlayout="page5" />
        </row>
        <row> <!-- painted bike lanes -->
            <button type="tag" label="start bike lane" />
            <button type="tag" label="left only" />
            <button type="tag" label="right only" />
            <button type="tag" label="end bike lane" />
        </row>
        <row> <!-- signage regarding shared use with pedestrians -->
            <button type="tag" label="start foot/cycleway" />
            <button type="tag" label="start cycleway" />
            <button type="tag" label="end foot/cycleway" />
            <button type="tag" label="end cycleway" />
        </row>
    </layout>
    <layout name="page5">
        <row> <!-- audio/picture/text notes -->
            <button type="voicerec" icon="logo_voice" />
            <button type="picture" icon="logo_camera" />
            <button type="textnote" icon="logo_textnote" />
            <button type="page" label="next page" targetlayout="page6" />
        </row>
        <row> <!-- special cases of signage or paint -->
            <button type="tag" label="advanced stopping line" /> <!-- https://wiki.openstreetmap.org/wiki/Tag:cycleway%3Dasl -->
            <button type="tag" label="right on red" /> <!-- https://wiki.openstreetmap.org/wiki/Red_turn -->
            <button type="tag" label="early release light" /> <!-- https://wiki.openstreetmap.org/wiki/Key:traffic_signals:bicycle_early_release -->
        </row>
        <row> <!-- rare tags for surface and smoothness -->
            <button type="tag" label="excellent" />
            <button type="tag" label="wood" />
            <button type="tag" label="grass" />
            <button type="tag" label="fine gravel" /> 
        </row>
    </layout>
    <layout name="page6">
        <row> <!-- various obstacles -->
            <button type="tag" label="bollard" />
            <button type="tag" label="cycling gate" />
            <button type="tag" label="closed gate" />
            <button type="page" label="first page" targetlayout="page1" />
        </row>
        <row> <!-- incorrect/incomplete OSM data -->
            <button type="tag" label="oneway, cars no entry" />
            <button type="tag" label="oneway, bikes no entry" />
            <button type="tag" label="private, no entry" />
        </row>
        <row> <!-- incorrect/incomplete OSM data -->
            <button type="tag" label="steps down" />
            <button type="tag" label="steps up" />
            <button type="tag" label="missing road" />
        </row>
    </layout>
</layouts>